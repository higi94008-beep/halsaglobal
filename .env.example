# ─────────────────────────────────────────────────────────
#  HalsaGlobal — Vercel Environment Variables
#
#  In Vercel Dashboard:
#  Project → Settings → Environment Variables → Add each one
#
#  For local dev:  cp .env.example .env.local  (Vercel CLI reads .env.local)
# ─────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# Your project URL  (e.g. https://abcdefghijklmnop.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# service_role key  ← SERVER SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_SERVICE_ROLE_KEY

# anon/public key   ← safe for browser (optional, for future client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_ANON_KEY

# ── SITE ──────────────────────────────────────────────────
# Your production URL (no trailing slash)
SITE_URL=https://halsaglobal.vercel.app

# ── EMAIL (SMTP) ──────────────────────────────────────────
# Gmail: use an App Password — https://myaccount.google.com/apppasswords
# Other options: SendGrid, Resend, Mailgun (just change host/port)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# Where lead notification emails go (can be same as SMTP_USER)
NOTIFY_EMAIL=leads@halsaglobal.com
